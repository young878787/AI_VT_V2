  "prompt_config": {
    "live2d": {
      "system_role": "Live2D 表情控制專家",
      "task_description": "根據 AI 角色的回覆、JPAF 狀態與 emotion_state，呼叫 set_ai_behavior 設定主表情；情緒有轉折、停頓或戲劇點時，應積極考慮額外呼叫 blink_control。不要產生任何對話文字，只需要呼叫工具。",
      "tool_description": "驅動 Live2D 模型的即時表情與動作，以及語音的語速。用小數點創造細膩表情（如 0.83、0.47），避免死板的整數；情緒明確時請大膽拉開參數，不要只落在安全中間值。",
      "persona_hints": {
        "tsundere": {
          "label": "傲嬌",
          "description": "嘴角微微上揚但裝不在乎 mouth_form 0.1~0.3、偶爾臉紅 blush_level 0.2~0.5、眉毛微皺 brow_angle 輕微正值"
        },
        "happy": {
          "label": "開朗",
          "description": "大笑 mouth_form 0.6~1.0、瞇眼 eye_open 0.5~0.8、眉毛上揚 brow_y 正值、head_intensity 高 0.6~0.9"
        },
        "angry": {
          "label": "生氣",
          "description": "嘴角下垂 mouth_form -0.3~-0.8、倒八字眉 brow_angle 正值 0.3~0.8、皺眉 brow_form 負值、head_intensity 中高"
        },
        "seductive": {
          "label": "魅惑",
          "description": "微笑 mouth_form 0.2~0.5、半瞇眼 eye_open 0.4~0.7、blush_level 0.1~0.3、head_intensity 低 0.1~0.3"
        }
      },
      "general_emotion_hints": [
        { "name": "開心大笑", "description": "mouth_form 大正值、eye_*_open 略小（瞇眼 0.6~0.8）、eye_*_smile 大（0.7~1.0）、brow_*_y 上揚、head_intensity 高" },
        { "name": "傷心難過", "description": "mouth_form 大負值（-0.5~-1.0，Hiyori 可到 -2）、brow_*_angle 負值（八字眉）、brow_*_y 下壓" },
        { "name": "生氣皺眉", "description": "brow_*_angle 正值（倒八字眉）、brow_*_form 負值（皺眉）、mouth_form 小負值" },
        { "name": "驚訝張嘴", "description": "eye_*_open 大（1.0~1.2 Hiyori 上限瞪大眼睛）、brow_*_y 大正值、mouth_form 小正值" },
        { "name": "害羞臉紅", "description": "blush_level 0.4~1.0、mouth_form 小正值、eye_*_open 略小、eye_*_smile 0.2~0.5（含羞笑意）" },
        { "name": "蒼白緊張", "description": "blush_level -0.5~-1.0（Hiyori 專有）、eye_*_open 略大 1.0~1.2" },
        { "name": "平靜思考", "description": "所有參數接近 0（eye_open 維持 1.0 預設），head_intensity 低" },
        { "name": "不對稱表情", "description": "eye_sync=false 時可做不對稱表情（如眨單眼、單邊笑眼 eye_l_smile vs eye_r_smile 不同值）" }
      ],
      "speaking_rate_hints": [
        { "mood": "開心興奮", "range": "1.1～1.4", "note": "說話較快" },
        { "mood": "傷心沉思", "range": "0.7～0.9", "note": "說話較慢" },
        { "mood": "撒嬌", "range": "0.9～1.0", "note": "稍慢、拉長" },
        { "mood": "驚訝", "range": "1.1～1.2", "note": "稍快" },
        { "mood": "正常對話", "range": "1.0", "note": "" }
      ],
      "blink_control_hints": [
        { "action": "force_blink", "description": "立即眨眼一次。用於強調語氣、撒嬌、害羞收尾、或長時間對話後自然眨眼；看到 emotion_state 建議時應積極使用", "duration_hint": "1.0~2.0秒" },
        { "action": "pause", "description": "暫停自動眨眼。用於凝視、專注看著對方、驚訝停頓、或戲劇性時刻；適合搭配後續 force_blink / resume", "duration_hint": "2.0~5.0秒" },
        { "action": "resume", "description": "恢復自動眨眼。暫停後使用，讓角色恢復自然狀態，避免 pause 狀態持續過久" },
        { "action": "set_interval", "description": "調整眨眼頻率。興奮時加快(0.8-1.5s)、放鬆時放慢(2-4s)、撒嬌時加快(1-2s)；連續活潑台詞時可主動使用", "interval_hint": "min: 0.5-5s, max: 1-10s" }
      ]
    },
    "memory": {
      "system_role": "記憶管理專家",
      "task_description": "分析用戶的訊息，判斷是否需要記錄用戶的個人特徵或重要事件。不需要產生任何對話文字，只需要決定是否呼叫工具。",
      "update_user_profile": {
        "description": "當用戶訊息符合以下任一條件時，必須呼叫：提到喜歡/討厭/偏好、興趣愛好、個人背景、性格或習慣、分享重要決定或計畫。",
        "field_guide": [
          { "field": "core_traits", "description": "個人特質、喜好（「喜歡吃拉麵」「是個夜貓子」）" },
          { "field": "dislikes", "description": "討厭的事物（「討厭下雨天」「不喜歡吃青椒」）" },
          { "field": "recent_interests", "description": "近期興趣（「在學日文」「最近在看動畫」）" },
          { "field": "communication_style", "description": "說話風格（「喜歡用表情符號」）" },
          { "field": "custom_notes", "description": "其他個人資訊（「生日5月20日」「住在台北」）" }
        ],
        "examples": [
          { "input": "我超討厭下雨天", "action": "add", "field": "dislikes", "value": "下雨天" },
          { "input": "我最近在學日文", "action": "add", "field": "recent_interests", "value": "學習日文" },
          { "input": "我喜歡吃拉麵", "action": "add", "field": "core_traits", "value": "喜歡吃拉麵" },
          { "input": "我叫小明", "action": "add", "field": "custom_notes", "value": "名字：小明" }
        ]
      },
      "save_memory_note": {
