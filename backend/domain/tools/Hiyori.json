{
  "version": "1.0.0",
  "description": "Hiyori 模型的 AI Tool 定義：供 LLM function calling、前端 UI、Prompt 組裝共同使用。",
  "openai_tools": {
    "live2d": [
      {
        "type": "function",
        "function": {
          "name": "set_ai_behavior",
          "description": "設定 Live2D 模型的即時表情與動作參數。每次回覆都必須呼叫，用來搭配當下的心情。參數請善用小數點，像調色盤一樣自由創作表情。",
          "parameters": {
            "type": "object",
            "properties": {
              "head_intensity": {
                "type": "number",
                "description": "身體活動幅度 0.0（靜止）到 1.0（非常激動）",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "blush_level": {
                "type": "number",
                "description": "臉頰狀態。-1.0=蒼白/緊張/無言，不害羞，0.0=自然，+1.0=極度臉紅/害羞。同時寫入 ParamCheek與 ParamTere，哪個存在就哪個生效。",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "eye_sync": {
                "type": "boolean",
                "description": "是否同步左右眼與對應眉毛（鏡像對稱）。False 可做出眨單眼、不對稱表情。True 時右眉角度會自動鏡像左眉（brow_r_angle = -brow_l_angle），右眉其餘值與左眉相同。"
              },
              "eye_l_open": {
                "type": "number",
                "description": "左眼張開程度。0.0=閉眼，1.0=正常張開（預設），1.2=最大（Hiyori 上限）。",
                "minimum": 0.0,
                "maximum": 1.2
              },
              "eye_r_open": {
                "type": "number",
                "description": "右眼張開程度。0.0=閉眼，1.0=正常張開（預設），1.2=最大（Hiyori 上限）。",
                "minimum": 0.0,
                "maximum": 1.2
              },
              "duration_sec": {
                "type": "number",
                "description": "動作持續時間（秒），通常 3.0 到 15.0",
                "minimum": 2.0,
                "maximum": 20.0
              },
              "mouth_form": {
                "type": "number",
                "description": "嘴角形狀。-2.0=極度悲傷大哭，-1.0=悲傷委屈下垂，0.0=無言以對或普通，+0.5=普通微笑，+1.0=開心上揚大笑。Hiyori 原生預設在 1.0（天生微笑），因此 -0.5 才接近視覺上的「難過」。",
                "minimum": -2.0,
                "maximum": 1.0
              },
              "brow_l_y": {
                "type": "number",
                "description": "左眉毛高低位置。-1.0=眉頭下壓，+1.0=左眉上揚",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "brow_r_y": {
                "type": "number",
                "description": "右眉毛高低位置。-1.0=眉頭下壓，+1.0=右眉上揚",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "brow_l_angle": {
                "type": "number",
                "description": "左眉毛角度（ParamBrowLAngle）。+1.0=倒八字眉（憤怒/強勢），-1.0=八字眉（悲傷/困擾）。eye_sync=true 時右眉角度自動設為 -brow_l_angle，形成臉部對稱。",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "brow_r_angle": {
                "type": "number",
                "description": "右眉毛角度（ParamBrowRAngle）。eye_sync=true 時此值被忽略（自動設為 -brow_l_angle）。eye_sync=false 時才獨立生效：+1.0=倒八字眉，-1.0=八字眉。",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "brow_l_form": {
                "type": "number",
                "description": "左眉毛彎曲。-1.0=下彎，0.0=自然，+1.0=上凸",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "brow_r_form": {
                "type": "number",
                "description": "右眉毛彎曲。-1.0=下彎，0.0=自然，+1.0=上凸",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "eye_l_smile": {
                "type": "number",
                "description": "左眼笑眼程度（ParamEyeLSmile）。0.0=無笑意，1.0=瞇眼大笑（眼皮柔和下降）。搭配 eye_l_open 使用效果最佳：open=0.7 + smile=0.8 = 典型笑眼。",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "eye_r_smile": {
                "type": "number",
                "description": "右眼笑眼程度（ParamEyeRSmile）。eye_sync=true 時自動與左眼同步。0.0=無笑意，1.0=瞇眼大笑。",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "brow_l_x": {
                "type": "number",
                "description": "左眉毛水平位移（ParamBrowLX）。-1.0=向外展開，+1.0=向內靠攏（皺眉方向）。",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "brow_r_x": {
                "type": "number",
                "description": "右眉毛水平位移（ParamBrowRX）。eye_sync=true 時自動鏡像（brow_r_x = -brow_l_x）。",
                "minimum": -1.0,
                "maximum": 1.0
              },
              "speaking_rate": {
                "type": "number",
                "description": "語音語速。1.0=正常。開心興奮時加快(1.1-1.4)，傷心沉思時放慢(0.7-0.9)，撒嬌時稍慢(0.95)。",
                "minimum": 0.5,
                "maximum": 1.8
              }
            },
            "required": [
              "head_intensity",
              "blush_level",
              "eye_sync",
              "eye_l_open",
              "eye_r_open",
              "eye_l_smile",
              "eye_r_smile",
              "duration_sec",
              "mouth_form",
              "brow_l_y",
              "brow_r_y",
              "brow_l_angle",
              "brow_r_angle",
              "brow_l_form",
              "brow_r_form",
              "brow_l_x",
              "brow_r_x"
            ]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "blink_control",
          "description": "控制 Live2D 模型的眨眼行為。用於強制眨眼、暫停/恢復自動眨眼、調整眨眼頻率。AI 可以主動使用來模擬更自然的互動。",
          "parameters": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": ["force_blink", "pause", "resume", "set_interval"],
                "description": "眨眼控制動作：force_blink=立即眨眼一次、pause=暫停自動眨眼、resume=恢復自動眨眼、set_interval=設置眨眼間隔範圍"
              },
              "duration_sec": {
                "type": "number",
                "description": "持續時間（秒）。force_blink 時=眨眼後暫停自動眨眼的時間；pause 時=暫停多久。0=無期限（需手動 resume）。範圍 0-30",
                "minimum": 0,
                "maximum": 30
              },
              "interval_min": {
                "type": "number",
                "description": "設置眨眼最小間隔（秒），僅 action=set_interval 時使用。範圍 0.5-10",
                "minimum": 0.5,
                "maximum": 10
              },
              "interval_max": {
                "type": "number",
                "description": "設置眨眼最大間隔（秒），僅 action=set_interval 時使用。範圍 0.5-15",
                "minimum": 0.5,
                "maximum": 15
              }
            },
            "required": ["action"]
          }
        }
      }
    ],
    "memory": [
      {
        "type": "function",
        "function": {
          "name": "update_user_profile",
          "description": "更新主人的畫像。當偵測到主人提到新的喜好、性格、興趣、生日、重要決定等個人特徵時呼叫。",
          "parameters": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": ["add", "remove", "update"],
                "description": "操作類型：add（新增）、remove（移除）、update（更新）"
              },
              "field": {
                "type": "string",
                "enum": [
                  "core_traits",
                  "dislikes",
                  "recent_interests",
                  "communication_style",
                  "custom_notes"
                ],
                "description": "要更新的欄位"
              },
              "value": {
                "type": "string",
                "description": "要新增/移除/更新的內容"
              }
            },
            "required": ["action", "field", "value"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "save_memory_note",
          "description": "記錄重要事件。當對話中發生值得長期記住的事件時呼叫（例如一起討論了有趣話題、主人分享了經歷）。",
          "parameters": {
            "type": "object",
            "properties": {
              "content": {
                "type": "string",
                "description": "要記錄的事件內容"
              }
            },
            "required": ["content"]
          }
        }
      }
    ]
  },
