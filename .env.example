# ============================================================
# AI Provider Selection
# 選擇使用哪個 AI 提供商: openrouter | nvidia
# ============================================================
AI_PROVIDER=openrouter

# ============================================================
# OpenRouter Configuration
# ============================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# ============================================================
# NVIDIA API Configuration
# ============================================================
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=qwen/qwen3-next-80b-a3b-instruct

# ============================================================
# VTube Studio Configuration
# ============================================================
VTS_PLUGIN_NAME=VTS Tool
VTS_DEVELOPER=YourName
VTS_AUTH_TOKEN=

# ============================================================
# Server Configuration
# ============================================================
BACKEND_PORT=9000
VITE_BACKEND_PORT=9000
FRONTEND_PORT=5287
