# ============================================================
# AI Provider Selection
# 選擇使用哪個 AI 提供商: openrouter | nvidia | google | qwen
# ============================================================
AI_PROVIDER=openrouter

# ============================================================
# OpenRouter Configuration
# ============================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# ============================================================
# NVIDIA API Configuration
# ============================================================
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=qwen/qwen3-next-80b-a3b-instruct
# NVIDIA 推理思考模式（預設關閉可降低延遲）
AI_ENABLE_THINKING=false

# ============================================================
# Google AI Studio Configuration (Gemini)
# 官方 OpenAI 相容端點: https://ai.google.dev/gemini-api/docs/openai
# ============================================================
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GOOGLE_MODEL_NAME=gemini-2.0-flash

# ============================================================
# Qwen API (阿里雲 DashScope) Configuration
# 地域端點選擇:
#   新加坡: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   美國(弗吉尼亞): https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   中國北京: https://dashscope.aliyuncs.com/compatible-mode/v1
#   中國香港: https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
# ============================================================
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen3.6-plus
# 後備模型：當主模型呼叫失敗時自動切換（留空則不啟用後備）
QWEN_FALLBACK_MODEL_NAME=qwen-turbo

# 對話持久化（可選）
# true: 依 session_id 將 user/assistant 對話寫入 backend/memory/sessions
CHAT_PERSISTENCE_ENABLED=false
# 每個 session 最多保留訊息數（user+assistant）
CHAT_PERSISTENCE_MAX_MESSAGES=80
# 前端是否附帶 session_id（需與後端開關搭配）
VITE_CHAT_PERSISTENCE_ENABLED=false

# ============================================================
# Google Cloud TTS Configuration (Chirp 3 HD)
# ============================================================
# 是否啟用 TTS 語音合成
TTS_ENABLED=false

# Google Cloud SDK ADC (Application Default Credentials)
# 請在終端機執行 `gcloud auth application-default login` 登入
# SDK 會自動讀取快取，無需特別設定金鑰路徑
# TTS 語言與語音選擇
# 支援的語言: ja-JP (日文), cmn-CN (中文簡體), en-US (英文) 等
# 語音名稱格式: {語言}-Chirp3-HD-{語音名}
# 可用語音: Aoede, Achernar, Kore, Leda, Charon 等
TTS_LANGUAGE=ja-JP
TTS_VOICE_NAME=ja-JP-Chirp3-HD-Aoede

# ============================================================
# VTube Studio Configuration
# ============================================================
VTS_PLUGIN_NAME=VTS Tool
VTS_DEVELOPER=YourName
VTS_AUTH_TOKEN=

# ============================================================
# Server Configuratin
# ============================================================
BACKEND_PORT=9000
FRONTEND_PORT=5287
